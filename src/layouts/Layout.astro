---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Cursor from '../components/Cursor.astro';
import CursorTrail from '../components/CursorTrail.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Prathamesh Mishra — Data & Product Analyst | Power BI, SQL, AI Systems',
  description = 'Data & product analyst in London. Power BI, SQL, GA4 and production AI systems. +30% acquisition, −22% CAC, ±8% forecasting.',
} = Astro.props;

const ogImage = '/og.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <ClientRouter />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Prathamesh Mishra",
        "jobTitle": "Data & Product Analyst",
        "url": "https://portfolio-iota-taupe-34.vercel.app",
        "email": "mprathamesh2023@gmail.com",
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "UK" },
        "sameAs": [
          "https://github.com/Mprtham",
          "https://linkedin.com/in/prathamesh-mishra-9a8b36212",
          "https://medium.com/@mishraprathamesh2303"
        ]
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>
  <body>
    <Nav />
    <ThemeToggle />
    <slot />
    <Cursor />
    <CursorTrail />
    <script>
      // IntersectionObserver does NOT work with Lenis (Lenis intercepts native scroll).
      // Use getBoundingClientRect() in a RAF loop instead — always reflects true visual position.
      let revealRaf: number | null = null;

      function initReveal() {
        if (revealRaf) { cancelAnimationFrame(revealRaf); revealRaf = null; }

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = Array.from(document.querySelectorAll<HTMLElement>('.reveal:not(.visible)'));
        if (!els.length) return;
        if (reduced) { els.forEach(el => el.classList.add('visible')); return; }

        const vh = window.innerHeight;
        const pending: HTMLElement[] = [];

        els.forEach(el => {
          if (el.getBoundingClientRect().top < vh * 0.9) {
            el.classList.add('visible');
          } else {
            // Hide instantly: override the CSS transition so the hide is a snap, not an animation
            el.style.transition = 'none';
            el.style.opacity = '0';
            el.style.transform = 'translateY(28px)';
            pending.push(el);
          }
        });

        if (!pending.length) return;

        // Next frame: restore CSS transition (elements are now hidden; CSS transition takes over again).
        // Tick starts in the frame after that so elements are definitely painted-hidden before we watch them.
        requestAnimationFrame(() => {
          pending.forEach(el => { el.style.transition = ''; });

          function tick() {
            if (!pending.length) { revealRaf = null; return; }
            const cvh = window.innerHeight;
            for (let i = pending.length - 1; i >= 0; i--) {
              const el = pending[i];
              if (el.getBoundingClientRect().top < cvh * 0.88) {
                // CSS transition is defined (from .reveal in global.css) — just change the values
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
                el.classList.add('visible');
                pending.splice(i, 1);
              }
            }
            revealRaf = requestAnimationFrame(tick);
          }

          revealRaf = requestAnimationFrame(tick);
        });
      }

      initReveal();
      document.addEventListener('astro:page-load', initReveal);
      document.addEventListener('astro:before-swap', () => {
        if (revealRaf) { cancelAnimationFrame(revealRaf); revealRaf = null; }
      });
    </script>

    <script>
      import Lenis from 'lenis';
      let lenis: InstanceType<typeof Lenis> | null = null;
      let lenisRaf: number | null = null;

      function initLenis() {
        if (lenis) lenis.destroy();
        if (lenisRaf) cancelAnimationFrame(lenisRaf);
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });

        function raf(time: number) {
          lenis!.raf(time);
          lenisRaf = requestAnimationFrame(raf);
        }
        lenisRaf = requestAnimationFrame(raf);
      }

      document.addEventListener('astro:page-load', initLenis);
      document.addEventListener('astro:before-swap', () => {
        if (lenis) { lenis.destroy(); lenis = null; }
        if (lenisRaf) { cancelAnimationFrame(lenisRaf); lenisRaf = null; }
      });
    </script>

    <script>
      function initMagnetic() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const hasHover = window.matchMedia('(hover: hover)').matches;
        if (reduced || !hasHover) return;

        document.querySelectorAll<HTMLElement>('.btn-primary, .btn-secondary, .nav-cta').forEach(el => {
          el.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = el.getBoundingClientRect();
            const dx = (e.clientX - (rect.left + rect.width / 2)) * 0.3;
            const dy = (e.clientY - (rect.top + rect.height / 2)) * 0.3;
            el.style.transform = `translate(${dx}px, ${dy}px)`;
          });
          el.addEventListener('mouseleave', () => {
            el.style.transform = '';
          });
        });
      }
      document.addEventListener('astro:page-load', initMagnetic);
    </script>
  </body>
</html>
