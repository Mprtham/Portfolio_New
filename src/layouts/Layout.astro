---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Cursor from '../components/Cursor.astro';
import CursorTrail from '../components/CursorTrail.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Prathamesh Mishra — Data & Product Analyst | Power BI, SQL, AI Systems',
  description = 'Data & product analyst in London. Power BI, SQL, GA4 and production AI systems. +30% acquisition, −22% CAC, ±8% forecasting.',
} = Astro.props;

const ogImage = '/og.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <ClientRouter />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Prathamesh Mishra",
        "jobTitle": "Data & Product Analyst",
        "url": "https://portfolio-iota-taupe-34.vercel.app",
        "email": "mprathamesh2023@gmail.com",
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "UK" },
        "sameAs": [
          "https://github.com/Mprtham",
          "https://linkedin.com/in/prathamesh-mishra-9a8b36212",
          "https://medium.com/@mishraprathamesh2303"
        ]
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>
  <body>
    <Nav />
    <ThemeToggle />
    <slot />
    <Cursor />
    <CursorTrail />
    <script>
      function initReveal() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const vh = window.innerHeight;
        const EASE = 'cubic-bezier(0.22,1,0.36,1)';

        // Skip elements already revealed
        const els = Array.from(document.querySelectorAll<HTMLElement>('.reveal:not(.visible)'));
        if (!els.length) return;

        if (reduced) {
          els.forEach(el => el.classList.add('visible'));
          return;
        }

        // Separate in-viewport vs below-fold
        const belowFold: HTMLElement[] = [];
        els.forEach(el => {
          if (el.getBoundingClientRect().top < vh * 0.9) {
            el.classList.add('visible'); // already on screen — no animation needed
          } else {
            // Hide before observer fires
            el.style.opacity = '0';
            el.style.transform = 'translateY(28px)';
            belowFold.push(el);
          }
        });

        if (!belowFold.length) return;

        const observer = new IntersectionObserver(entries => {
          entries.forEach(e => {
            if (!e.isIntersecting) return;
            const el = e.target as HTMLElement;
            const delay = parseInt(getComputedStyle(el).getPropertyValue('--delay').trim()) || 0;

            // rAF ensures browser has committed the opacity:0 state before we transition
            requestAnimationFrame(() => {
              el.style.transition = `opacity 0.65s ${EASE} ${delay}ms, transform 0.65s ${EASE} ${delay}ms`;
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
              el.classList.add('visible');
            });

            observer.unobserve(el);
          });
        }, { threshold: 0.07 });

        belowFold.forEach(el => observer.observe(el));
      }

      initReveal();
      document.addEventListener('astro:page-load', initReveal);
    </script>

    <script>
      import Lenis from 'lenis';
      let lenis: InstanceType<typeof Lenis> | null = null;
      let lenisRaf: number | null = null;

      function initLenis() {
        if (lenis) lenis.destroy();
        if (lenisRaf) cancelAnimationFrame(lenisRaf);
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });

        function raf(time: number) {
          lenis!.raf(time);
          lenisRaf = requestAnimationFrame(raf);
        }
        lenisRaf = requestAnimationFrame(raf);
      }

      document.addEventListener('astro:page-load', initLenis);
      document.addEventListener('astro:before-swap', () => {
        if (lenis) { lenis.destroy(); lenis = null; }
        if (lenisRaf) { cancelAnimationFrame(lenisRaf); lenisRaf = null; }
      });
    </script>

    <script>
      function initMagnetic() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const hasHover = window.matchMedia('(hover: hover)').matches;
        if (reduced || !hasHover) return;

        document.querySelectorAll<HTMLElement>('.btn-primary, .btn-secondary, .nav-cta').forEach(el => {
          el.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = el.getBoundingClientRect();
            const dx = (e.clientX - (rect.left + rect.width / 2)) * 0.3;
            const dy = (e.clientY - (rect.top + rect.height / 2)) * 0.3;
            el.style.transform = `translate(${dx}px, ${dy}px)`;
          });
          el.addEventListener('mouseleave', () => {
            el.style.transform = '';
          });
        });
      }
      document.addEventListener('astro:page-load', initMagnetic);
    </script>
  </body>
</html>
