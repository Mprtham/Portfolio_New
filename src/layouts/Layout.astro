---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Cursor from '../components/Cursor.astro';
import CursorTrail from '../components/CursorTrail.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { ClientRouter } from 'astro:transitions';
import sg700url from '@fontsource/space-grotesk/files/space-grotesk-latin-700-normal.woff2';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Prathamesh Mishra — Data & Product Analyst | Power BI, SQL, AI Systems',
  description = 'Data & product analyst in London. Power BI, SQL, GA4 and production AI systems. +30% acquisition, −22% CAC, ±8% forecasting.',
} = Astro.props;

const ogImage = '/og.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <ClientRouter />
    <link rel="preload" href={sg700url} as="font" type="font/woff2" crossorigin />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Prathamesh Mishra",
        "jobTitle": "Data & Product Analyst",
        "url": "https://portfolio-iota-taupe-34.vercel.app",
        "email": "mprathamesh2023@gmail.com",
        "address": { "@type": "PostalAddress", "addressLocality": "London", "addressCountry": "UK" },
        "sameAs": [
          "https://github.com/Mprtham",
          "https://linkedin.com/in/prathamesh-mishra-9a8b36212",
          "https://medium.com/@mishraprathamesh2303"
        ]
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.add('light');
    </script>
  </head>
  <body>
    <div class="scanlines" aria-hidden="true"></div>
    <Nav />
    <ThemeToggle />
    <slot />
    <Cursor />
    <CursorTrail />
    <script>
      let revealObserver: IntersectionObserver | null = null;

      function initReveals() {
        if (revealObserver) revealObserver.disconnect();

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const reveals = document.querySelectorAll<Element>('.reveal:not(.visible)');

        if (reduced) {
          reveals.forEach(el => el.classList.add('visible'));
          return;
        }

        revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver!.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -20px 0px' });

        reveals.forEach(el => revealObserver!.observe(el));
      }

      document.addEventListener('astro:page-load', initReveals);
      document.addEventListener('astro:before-swap', () => {
        if (revealObserver) { revealObserver.disconnect(); revealObserver = null; }
      });
    </script>

    <script>
      import Lenis from 'lenis';
      let lenis: InstanceType<typeof Lenis> | null = null;
      let lenisRaf: number | null = null;

      function initLenis() {
        if (lenis) lenis.destroy();
        if (lenisRaf) cancelAnimationFrame(lenisRaf);
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          syncTouch: true,
          touchMultiplier: 1.5,
        });

        function raf(time: number) {
          lenis!.raf(time);
          lenisRaf = requestAnimationFrame(raf);
        }
        lenisRaf = requestAnimationFrame(raf);
      }

      document.addEventListener('astro:page-load', initLenis);
      document.addEventListener('astro:before-swap', () => {
        if (lenis) { lenis.destroy(); lenis = null; }
        if (lenisRaf) { cancelAnimationFrame(lenisRaf); lenisRaf = null; }
      });
    </script>

    <script>
      function initMagnetic() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const hasHover = window.matchMedia('(hover: hover)').matches;
        if (reduced || !hasHover) return;

        document.querySelectorAll<HTMLElement>('.btn-primary, .btn-secondary, .nav-cta').forEach(el => {
          el.addEventListener('mousemove', (e: MouseEvent) => {
            const rect = el.getBoundingClientRect();
            const dx = (e.clientX - (rect.left + rect.width / 2)) * 0.3;
            const dy = (e.clientY - (rect.top + rect.height / 2)) * 0.3;
            el.style.transform = `translate(${dx}px, ${dy}px)`;
          });
          el.addEventListener('mouseleave', () => {
            el.style.transform = '';
          });
        });
      }
      document.addEventListener('astro:page-load', initMagnetic);
    </script>
  </body>
</html>
