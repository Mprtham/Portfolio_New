---
---
<canvas id="dot-grid-canvas" class="dot-grid-canvas" aria-hidden="true"></canvas>

<style>
  .dot-grid-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>

<script>
  let dotRaf: number | null = null;
  let dotObserverRaf: number | null = null;
  let currentMouseHandler: ((e: MouseEvent) => void) | null = null;
  let currentResizeHandler: (() => void) | null = null;
  let visibilityHandler: (() => void) | null = null;
  let dotObserver: IntersectionObserver | null = null;
  let heroVisible = true;

  const SPACING = 46;
  const PUSH_RADIUS = 130;
  const PUSH_STRENGTH = 5;
  const FRICTION = 0.82;
  const SPRING = 0.055;

  type Dot = { baseX: number; baseY: number; x: number; y: number; vx: number; vy: number };

  function initDotGrid() {
    if (dotRaf) cancelAnimationFrame(dotRaf);
    if (dotObserverRaf) { cancelAnimationFrame(dotObserverRaf); dotObserverRaf = null; }
    if (currentMouseHandler) window.removeEventListener('mousemove', currentMouseHandler);
    if (currentResizeHandler) window.removeEventListener('resize', currentResizeHandler);
    if (visibilityHandler) document.removeEventListener('visibilitychange', visibilityHandler);
    if (dotObserver) { dotObserver.disconnect(); dotObserver = null; }
    heroVisible = true;

    const canvas = document.getElementById('dot-grid-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d')!;
    const isTouch = window.matchMedia('(hover: none)').matches;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dpr = Math.min(devicePixelRatio, 2);

    let w = 0, h = 0;
    let mouseX = -9999, mouseY = -9999;
    let targetX = -9999, targetY = -9999;
    let dots: Dot[] = [];

    function resize() {
      const parent = canvas.parentElement;
      if (!parent) return;
      const rect = parent.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.scale(dpr, dpr);
      generateDots();
    }

    function generateDots() {
      dots = [];
      const cols = Math.ceil(w / SPACING) + 1;
      const rows = Math.ceil(h / SPACING) + 1;
      const offsetX = (w - (cols - 1) * SPACING) / 2;
      const offsetY = (h - (rows - 1) * SPACING) / 2;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const bx = offsetX + c * SPACING;
          const by = offsetY + r * SPACING;
          dots.push({ baseX: bx, baseY: by, x: bx, y: by, vx: 0, vy: 0 });
        }
      }
    }

    currentMouseHandler = (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      targetX = e.clientX - rect.left;
      targetY = e.clientY - rect.top;
    };
    currentResizeHandler = resize;

    window.addEventListener('mousemove', currentMouseHandler);
    window.addEventListener('resize', currentResizeHandler);
    resize();

    if (reduced) {
      ctx.clearRect(0, 0, w, h);
      dots.forEach(dot => {
        ctx.beginPath();
        ctx.arc(dot.baseX, dot.baseY, 1.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(163, 230, 53, 0.18)';
        ctx.fill();
      });
      return;
    }

    if (isTouch) {
      let lastFrame = 0;
      const touchTick = (ts: number) => {
        if (document.hidden) { dotRaf = null; return; }
        if (ts - lastFrame < 48) { dotRaf = requestAnimationFrame(touchTick); return; }
        lastFrame = ts;
        ctx.clearRect(0, 0, w, h);
        dots.forEach((dot, i) => {
          const opacity = 0.12 + 0.07 * Math.sin(ts / 3200 + i * 0.7);
          ctx.beginPath();
          ctx.arc(dot.baseX, dot.baseY, 1.5, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(163, 230, 53, ${opacity})`;
          ctx.fill();
        });
        dotRaf = requestAnimationFrame(touchTick);
      };

      visibilityHandler = () => { if (!document.hidden && !dotRaf) touchTick(performance.now()); };
      document.addEventListener('visibilitychange', visibilityHandler);
      touchTick(performance.now());

      dotObserverRaf = requestAnimationFrame(() => {
        dotObserverRaf = null;
        dotObserver = new IntersectionObserver((entries) => {
          heroVisible = entries[0].isIntersecting;
          if (!heroVisible && dotRaf) { cancelAnimationFrame(dotRaf); dotRaf = null; }
          else if (heroVisible && !dotRaf && !document.hidden) touchTick(performance.now());
        }, { threshold: 0 });
        dotObserver.observe(canvas);
      });
      return;
    }

    function tick() {
      // Only guard on tab visibility — heroVisible is managed externally by IO
      if (document.hidden) { dotRaf = null; return; }

      mouseX += (targetX - mouseX) * 0.1;
      mouseY += (targetY - mouseY) * 0.1;

      ctx.clearRect(0, 0, w, h);

      dots.forEach(dot => {
        const dx = dot.x - mouseX;
        const dy = dot.y - mouseY;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < PUSH_RADIUS && mouseX > -100) {
          const t = 1 - dist / PUSH_RADIUS;
          const force = t * t * PUSH_STRENGTH;
          dot.vx += (dx / (dist || 1)) * force;
          dot.vy += (dy / (dist || 1)) * force;
        }

        dot.vx *= FRICTION;
        dot.vy *= FRICTION;
        dot.x += dot.vx;
        dot.y += dot.vy;
        dot.x += (dot.baseX - dot.x) * SPRING;
        dot.y += (dot.baseY - dot.y) * SPRING;

        const curDx = dot.x - mouseX;
        const curDy = dot.y - mouseY;
        const curDist = Math.sqrt(curDx * curDx + curDy * curDy);
        const proximity = mouseX > -100 ? Math.max(0, 1 - curDist / PUSH_RADIUS) : 0;

        const radius = 1.5 + proximity * 2.5;
        const opacity = 0.18 + proximity * 0.7;

        ctx.beginPath();
        ctx.arc(dot.x, dot.y, radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(163, 230, 53, ${opacity})`;
        ctx.fill();
      });

      dotRaf = requestAnimationFrame(tick);
    }

    visibilityHandler = () => { if (!document.hidden && !dotRaf) tick(); };
    document.addEventListener('visibilitychange', visibilityHandler);

    tick(); // start immediately — don't wait for IO

    // Delay IO setup by one frame so layout is settled before the first intersection check.
    // Prevents a false-negative isIntersecting=false from killing the loop on initial load.
    dotObserverRaf = requestAnimationFrame(() => {
      dotObserverRaf = null;
      dotObserver = new IntersectionObserver((entries) => {
        heroVisible = entries[0].isIntersecting;
        if (!heroVisible && dotRaf) { cancelAnimationFrame(dotRaf); dotRaf = null; }
        else if (heroVisible && !dotRaf && !document.hidden) tick();
      }, { threshold: 0 });
      dotObserver.observe(canvas);
    });
  }

  initDotGrid();
  document.addEventListener('astro:page-load', initDotGrid);
  document.addEventListener('astro:before-swap', () => {
    if (dotRaf) cancelAnimationFrame(dotRaf);
    if (dotObserverRaf) { cancelAnimationFrame(dotObserverRaf); dotObserverRaf = null; }
    if (currentMouseHandler) window.removeEventListener('mousemove', currentMouseHandler);
    if (currentResizeHandler) window.removeEventListener('resize', currentResizeHandler);
    if (visibilityHandler) document.removeEventListener('visibilitychange', visibilityHandler);
    if (dotObserver) { dotObserver.disconnect(); dotObserver = null; }
    dotRaf = null; currentMouseHandler = null; currentResizeHandler = null;
    visibilityHandler = null; heroVisible = true;
  });
</script>
