---
---
<canvas id="hero-three" class="hero-three-canvas" aria-hidden="true"></canvas>

<style>
  .hero-three-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
</style>

<script>
  import * as THREE from 'three';

  let threeRaf: number | null = null;
  let threeResizeH: (() => void) | null = null;
  let threeMouseH: ((e: MouseEvent) => void) | null = null;
  let renderer: THREE.WebGLRenderer | null = null;

  function cleanupThree() {
    if (threeRaf) { cancelAnimationFrame(threeRaf); threeRaf = null; }
    if (threeResizeH) { window.removeEventListener('resize', threeResizeH); threeResizeH = null; }
    if (threeMouseH) { window.removeEventListener('mousemove', threeMouseH); threeMouseH = null; }
    if (renderer) { renderer.dispose(); renderer = null; }
    // Restore fallback grid visibility so it can be re-evaluated on next init
    const dotGrid = document.getElementById('dot-grid-canvas');
    if (dotGrid) dotGrid.style.display = '';
  }

  function hasBrowserWebGL(): boolean {
    try {
      const probe = document.createElement('canvas');
      return !!(probe.getContext('webgl') || probe.getContext('experimental-webgl'));
    } catch { return false; }
  }

  function initHeroThree() {
    cleanupThree();

    const canvas = document.getElementById('hero-three') as HTMLCanvasElement | null;
    if (!canvas) return;
    const parent = canvas.parentElement;
    if (!parent) return;

    const dotGrid = document.getElementById('dot-grid-canvas') as HTMLCanvasElement | null;

    if (!hasBrowserWebGL()) {
      canvas.style.display = 'none';
      return;
    }

    let W = parent.clientWidth;
    let H = parent.clientHeight;
    if (W === 0 || H === 0) return;

    try {
      renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    } catch {
      canvas.style.display = 'none';
      return;
    }

    // WebGL working: hide the dot-grid fallback
    if (dotGrid) dotGrid.style.display = 'none';
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.setSize(W, H);
    renderer.setClearColor(0x000000, 0);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(65, W / H, 0.1, 100);
    camera.position.z = 18;

    // Build a radial-gradient texture for glowing points
    const texSize = 64;
    const texCanvas = document.createElement('canvas');
    texCanvas.width = texSize;
    texCanvas.height = texSize;
    const tc = texCanvas.getContext('2d')!;
    const grad = tc.createRadialGradient(32, 32, 0, 32, 32, 32);
    grad.addColorStop(0,   'rgba(232,164,74,1)');
    grad.addColorStop(0.25,'rgba(232,164,74,0.8)');
    grad.addColorStop(0.6, 'rgba(232,164,74,0.25)');
    grad.addColorStop(1,   'rgba(232,164,74,0)');
    tc.fillStyle = grad;
    tc.fillRect(0, 0, texSize, texSize);
    const glowTex = new THREE.CanvasTexture(texCanvas);

    // Particles
    const COUNT = 85;
    const posArr = new Float32Array(COUNT * 3);
    const vels: Array<{ x: number; y: number; z: number }> = [];
    const BOUNDS = { x: 13, y: 7.5, z: 5 };

    for (let i = 0; i < COUNT; i++) {
      posArr[i * 3]     = (Math.random() - 0.5) * BOUNDS.x * 2;
      posArr[i * 3 + 1] = (Math.random() - 0.5) * BOUNDS.y * 2;
      posArr[i * 3 + 2] = (Math.random() - 0.5) * BOUNDS.z * 2;
      vels.push({
        x: (Math.random() - 0.5) * 0.005,
        y: (Math.random() - 0.5) * 0.004,
        z: (Math.random() - 0.5) * 0.003,
      });
    }

    const pGeo = new THREE.BufferGeometry();
    const pAttr = new THREE.BufferAttribute(posArr, 3);
    pAttr.setUsage(THREE.DynamicDrawUsage);
    pGeo.setAttribute('position', pAttr);

    const pMat = new THREE.PointsMaterial({
      size: 0.45,
      map: glowTex,
      transparent: true,
      opacity: 0.9,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
    });
    const points = new THREE.Points(pGeo, pMat);
    scene.add(points);

    // Connection lines
    const MAX_SEGS = 600;
    const lArr = new Float32Array(MAX_SEGS * 6);
    const lGeo = new THREE.BufferGeometry();
    const lAttr = new THREE.BufferAttribute(lArr, 3);
    lAttr.setUsage(THREE.DynamicDrawUsage);
    lGeo.setAttribute('position', lAttr);
    lGeo.setDrawRange(0, 0);

    const lMat = new THREE.LineBasicMaterial({
      color: 0xe8a44a,
      transparent: true,
      opacity: 0.14,
      blending: THREE.AdditiveBlending,
    });
    const lines = new THREE.LineSegments(lGeo, lMat);
    scene.add(lines);

    const DIST_SQ = 5.2 * 5.2;

    let tRotY = 0;
    let tRotX = 0;

    threeMouseH = (e: MouseEvent) => {
      tRotY = ((e.clientX / window.innerWidth) - 0.5) * 0.5;
      tRotX = ((e.clientY / window.innerHeight) - 0.5) * -0.25;
    };
    window.addEventListener('mousemove', threeMouseH);

    threeResizeH = () => {
      W = parent.clientWidth;
      H = parent.clientHeight;
      if (W === 0 || H === 0 || !renderer) return;
      camera.aspect = W / H;
      camera.updateProjectionMatrix();
      renderer.setSize(W, H);
    };
    window.addEventListener('resize', threeResizeH);

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      renderer.render(scene, camera);
      return;
    }

    function animate() {
      threeRaf = requestAnimationFrame(animate);

      for (let i = 0; i < COUNT; i++) {
        posArr[i * 3]     += vels[i].x;
        posArr[i * 3 + 1] += vels[i].y;
        posArr[i * 3 + 2] += vels[i].z;
        if (Math.abs(posArr[i * 3])     > BOUNDS.x) vels[i].x *= -1;
        if (Math.abs(posArr[i * 3 + 1]) > BOUNDS.y) vels[i].y *= -1;
        if (Math.abs(posArr[i * 3 + 2]) > BOUNDS.z) vels[i].z *= -1;
      }
      pAttr.needsUpdate = true;

      let li = 0;
      outer: for (let i = 0; i < COUNT; i++) {
        const ax = posArr[i * 3], ay = posArr[i * 3 + 1], az = posArr[i * 3 + 2];
        for (let j = i + 1; j < COUNT; j++) {
          if (li >= MAX_SEGS) break outer;
          const bx = posArr[j * 3], by = posArr[j * 3 + 1], bz = posArr[j * 3 + 2];
          if ((bx - ax) ** 2 + (by - ay) ** 2 + (bz - az) ** 2 < DIST_SQ) {
            lArr[li * 6]     = ax; lArr[li * 6 + 1] = ay; lArr[li * 6 + 2] = az;
            lArr[li * 6 + 3] = bx; lArr[li * 6 + 4] = by; lArr[li * 6 + 5] = bz;
            li++;
          }
        }
      }
      lGeo.setDrawRange(0, li * 2);
      lAttr.needsUpdate = true;

      scene.rotation.y += (tRotY - scene.rotation.y) * 0.04;
      scene.rotation.x += (tRotX - scene.rotation.x) * 0.04;
      scene.rotation.y += 0.0004;

      renderer!.render(scene, camera);
    }

    animate();
  }

  initHeroThree();
  document.addEventListener('astro:page-load', initHeroThree);
  document.addEventListener('astro:before-swap', cleanupThree);
</script>
