---
---
<div id="cursor-glow" aria-hidden="true"></div>

<style>
  #cursor-glow {
    position: fixed;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(closest-side, rgba(232, 164, 74, 0.15) 0%, transparent 100%);
    pointer-events: none;
    z-index: 1;
    transform: translate3d(-9999px, -9999px, 0);
    will-change: transform;
  }
  @media (hover: none) {
    #cursor-glow { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    #cursor-glow { display: none; }
  }
</style>

<script>
  let glowRaf: number | null = null;
  let glowMouseHandler: ((e: MouseEvent) => void) | null = null;

  let gx = -9999, gy = -9999, tx = -9999, ty = -9999, started = false;

  function initGlow() {
    if (glowRaf) cancelAnimationFrame(glowRaf);
    if (glowMouseHandler) window.removeEventListener('mousemove', glowMouseHandler);
    glowRaf = null; glowMouseHandler = null;
    started = false; gx = -9999; gy = -9999; tx = -9999; ty = -9999;

    const hasHover = window.matchMedia('(hover: hover)').matches;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!hasHover || reduced) return;

    const glow = document.getElementById('cursor-glow') as HTMLElement | null;
    if (!glow) return;

    glowMouseHandler = (e: MouseEvent) => {
      tx = e.clientX;
      ty = e.clientY;
      if (!started) { gx = tx; gy = ty; started = true; }
    };
    window.addEventListener('mousemove', glowMouseHandler);

    function tick() {
      gx += (tx - gx) * 0.15;
      gy += (ty - gy) * 0.15;
      glow.style.transform = `translate3d(${gx - 160}px, ${gy - 160}px, 0)`;
      glowRaf = requestAnimationFrame(tick);
    }
    tick();
  }

  initGlow();
  document.addEventListener('astro:page-load', initGlow);
  document.addEventListener('astro:before-swap', () => {
    if (glowRaf) cancelAnimationFrame(glowRaf);
    if (glowMouseHandler) window.removeEventListener('mousemove', glowMouseHandler);
    glowRaf = null; glowMouseHandler = null;
  });
</script>
