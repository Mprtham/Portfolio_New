---
---
<canvas id="trail-canvas" aria-hidden="true"></canvas>

<style>
  #trail-canvas {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 9997;
  }
</style>

<script>
  let trailRaf: number | null = null;
  let trailMouseHandler: ((e: MouseEvent) => void) | null = null;
  let trailResizeHandler: (() => void) | null = null;

  type Particle = { x: number; y: number; vx: number; vy: number; life: number; maxLife: number; size: number };

  function initTrail() {
    if (trailRaf) cancelAnimationFrame(trailRaf);
    if (trailMouseHandler) window.removeEventListener('mousemove', trailMouseHandler);
    if (trailResizeHandler) window.removeEventListener('resize', trailResizeHandler);

    const hasHover = window.matchMedia('(hover: hover)').matches;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!hasHover || reduced) return;

    const canvas = document.getElementById('trail-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;

    function resize() {
      const dpr = devicePixelRatio || 1;
      canvas.width = window.innerWidth * dpr;
      canvas.height = window.innerHeight * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    trailResizeHandler = resize;
    window.addEventListener('resize', trailResizeHandler);
    resize();

    const particles: Particle[] = [];

    trailMouseHandler = (e: MouseEvent) => {
      for (let i = 0; i < 4; i++) {
        particles.push({
          x: e.clientX,
          y: e.clientY,
          vx: (Math.random() - 0.5) * 3,
          vy: (Math.random() - 0.5) * 3 - 0.5,
          life: 45,
          maxLife: 45,
          size: 4 + Math.random() * 3,
        });
      }
    };

    window.addEventListener('mousemove', trailMouseHandler);

    function tick() {
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);

      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.vx *= 0.9;
        p.vy *= 0.9;
        p.vy -= 0.06;
        p.x += p.vx;
        p.y += p.vy;
        p.life--;

        if (p.life <= 0) { particles.splice(i, 1); continue; }

        const t = p.life / p.maxLife;
        const opacity = t * 0.85;
        const radius = p.size * t;

        ctx.beginPath();
        ctx.arc(p.x, p.y, radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(232, 164, 74, ${opacity})`;
        ctx.fill();
      }

      trailRaf = requestAnimationFrame(tick);
    }

    tick();
  }

  initTrail();
  document.addEventListener('astro:page-load', initTrail);
  document.addEventListener('astro:before-swap', () => {
    if (trailRaf) cancelAnimationFrame(trailRaf);
    if (trailMouseHandler) window.removeEventListener('mousemove', trailMouseHandler);
    if (trailResizeHandler) window.removeEventListener('resize', trailResizeHandler);
  });
</script>
