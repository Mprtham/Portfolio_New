---
interface Project {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  stack: string[];
  outcome: string;
  links: { label: string; href: string; external?: boolean }[];
  featured?: boolean;
  caseStudy?: string;
  theme?: string;
}

const projects: Project[] = [
  {
    id: 'charac',
    title: 'Charac: NHS-Integrated Pharmacy Platform',
    subtitle: 'Flagship Commercial Work',
    description: 'Built the Power BI + GA4 analytics layer for one of the UK\'s fastest-growing pharmacy platforms, turning prescription, delivery and consultation data into self-serve KPIs for pharmacy owners and driving acquisition growth on the patient app. Operates as a GDPR/NHS-IG data processor.',
    stack: ['Power BI', 'DAX', 'GA4', 'SQL', 'Python', 'ETL/ELT', 'GDPR / NHS IG'],
    outcome: 'Live analytics layer across patient app & pharmacy owner portal',
    links: [
      { label: 'Live Product ↗', href: 'https://charac.co.uk', external: true },
      { label: 'Case Study →', href: '/work/charac' },
    ],
    featured: true,
    caseStudy: '/work/charac',
    theme: 'flagship',
  },
  {
    id: 'sentinel',
    title: 'Sentinel: Real-Time Anomaly Detection Agent',
    subtitle: 'Production AI Systems',
    description: 'Ingests 100+ events/sec, flags statistical anomalies, and writes AI root-cause reports in <90s. Four-node LangGraph agent with <10% false-positive rate.',
    stack: ['LangGraph', 'Groq', 'DuckDB', 'Kafka', 'FastAPI', 'WebSocket', 'Docker'],
    outcome: '<10% false positive rate · <90s root-cause report',
    links: [
      { label: 'Case Study →', href: '/work/sentinel' },
      { label: 'View Code ↗', href: 'https://github.com/Mprtham/Real-Time-Anomaly-Detection-Agent', external: true },
    ],
    theme: 'ai',
  },
  {
    id: 'agentic-analyst',
    title: 'Agentic Data Analyst',
    subtitle: 'Production AI Systems',
    description: 'An autonomous analyst that runs end-to-end analysis on tabular data: ReAct loop over a registry of statistical tests, sandboxed Python execution, auto-generated reports.',
    stack: ['ReAct', 'Claude Sonnet', 'FastAPI', 'Polars', 'Plotly', 'ChromaDB', 'Docker'],
    outcome: 'Full end-to-end analysis in under 60s · sandboxed execution',
    links: [
      { label: 'Case Study →', href: '/work/agentic-data-analyst' },
      { label: 'View Code ↗', href: 'https://github.com/Mprtham/Agentic-Data-Analyst', external: true },
    ],
    theme: 'ai',
  },
  {
    id: 'coder-buddy',
    title: 'Coder Buddy: Multi-Agent AI Engineer',
    subtitle: 'Production AI Systems',
    description: 'Planner → Architect → Coder pipeline (LangGraph) that turns a prompt into a modular codebase with a streaming React UI.',
    stack: ['LangGraph', 'FastAPI', 'React', 'Vite', 'Tailwind', 'Groq'],
    outcome: 'Full codebase from a single prompt · streaming output',
    links: [
      { label: 'View Code ↗', href: 'https://github.com/Mprtham/coder-buddy', external: true },
    ],
    theme: 'ai',
  },
  {
    id: 'peopleops',
    title: 'PeopleOps Analytics: HR Attrition & Retention Platform',
    subtitle: 'Data Engineering & ML',
    description: 'End-to-end HR analytics on BigQuery + dbt + Power BI. Predicts who\'s at risk of leaving before they decide to. Leakage-proof point-in-time model, ROC-AUC 0.665, Precision@top-10% 55.1%, 3× PR-AUC over baseline. 75/75 dbt tests, Power BI engineered like code (PBIP in Git, BPA in CI).',
    stack: ['BigQuery', 'dbt', 'Power BI', 'PBIP', 'FastAPI', 'scikit-learn', 'SHAP', 'GitHub Actions'],
    outcome: 'ROC-AUC 0.665 · 3× PR-AUC baseline · 75/75 dbt tests',
    links: [
      { label: 'View Code ↗', href: 'https://github.com/Mprtham/peopleops-risk-intelligence', external: true },
      { label: 'Case Study →', href: '/work/peopleops' },
    ],
    caseStudy: '/work/peopleops',
    theme: 'data',
  },
  {
    id: 'sql-forge',
    title: 'SQL Forge: BigQuery + dbt Text-to-SQL Fine-Tuner',
    subtitle: 'Data Engineering & ML',
    description: 'Fine-tuned Phi-3-mini for BigQuery-dialect + dbt SQL. 15% → 55% exact-match accuracy, 60% → 90% parse accuracy. Model + datasets published to HuggingFace.',
    stack: ['Phi-3', 'Unsloth', 'LoRA', 'TRL DPO', 'BigQuery', 'dbt', 'FastAPI', 'Streamlit'],
    outcome: '15% → 55% exact-match accuracy · published to HuggingFace',
    links: [
      { label: 'View Code ↗', href: 'https://github.com/Mprtham/BigQuery-dbt-Text-to-SQL-Fine-Tuner', external: true },
    ],
    theme: 'data',
  },
  {
    id: 'rag-observatory',
    title: 'RAG Observatory: Production RAG with Full Observability',
    subtitle: 'Trustworthy AI',
    description: 'Cross-encoder reranking + citation enforcement + Langfuse tracing (latency, $/query, tokens) + RAGAS CI quality gates. The 70% of AI portfolios skip.',
    stack: ['FastAPI', 'ChromaDB', 'Groq', 'Langfuse', 'RAGAS', 'GitHub Actions', 'Docker'],
    outcome: 'Full latency/cost tracing · RAGAS CI gates · citation enforcement',
    links: [
      { label: 'View Code ↗', href: 'https://github.com/Mprtham/rag-observatory', external: true },
    ],
    theme: 'trustworthy',
  },
  {
    id: 'securequery',
    title: 'SecureQuery AI: Secure RAG with RBAC',
    subtitle: 'Trustworthy AI',
    description: 'Defence-in-depth role-based access (Finance/HR/C-level), PII masking, JWT, guardrails, cost tracking. 185 tests passing in ~2s.',
    stack: ['FastAPI', 'Qdrant', 'Azure OpenAI', 'Streamlit', 'JWT', 'Docker'],
    outcome: '185 tests in ~2s · Finance/HR/C-level RBAC · PII masking',
    links: [
      { label: 'Case Study →', href: '/work/securequery-ai' },
      { label: 'View Code ↗', href: 'https://github.com/Mprtham/securequery-ai', external: true },
    ],
    theme: 'trustworthy',
  },
  {
    id: 'stock-prediction',
    title: 'Stock Price Prediction with Sentiment Analysis',
    subtitle: 'Data Engineering & ML · MSc Dissertation',
    description: 'Hybrid LSTM + Prophet with NLP sentiment analysis over 80k+ tweets across 25 companies. Sharpe ratio 0.719.',
    stack: ['LSTM', 'Prophet', 'NLP', 'yfinance', 'Python', 'pandas'],
    outcome: 'Sharpe ratio 0.719 · 80k+ tweets · 25 companies',
    links: [
      { label: 'View Code ↗', href: 'https://github.com/Mprtham/Stock-price-prediction-using-sentiment-analysis-', external: true },
    ],
    theme: 'data',
  },
];

const themeLabels: Record<string, string> = {
  ai: 'Theme A: Production AI Systems',
  data: 'Theme B: Data Engineering & ML',
  trustworthy: 'Theme C: Trustworthy, Observable AI',
};
---

<section id="work">
  <div class="container">
    <div class="work-header reveal">
      <span class="section-label">03 Selected Work</span>
      <h2 class="work-title">Shipped. Measured.<br />In production.</h2>
    </div>

    <!-- Flagship -->
    {projects.filter(p => p.featured).map(p => (
      <div class="flagship-card card reveal" id={p.id}>
        <div class="card-preview" data-theme="flagship" aria-hidden="true"></div>
        <div class="flagship-inner">
          <div class="flagship-left">
            <div class="flagship-badge mono">★ Flagship / Commercial Client Work</div>
            <h3 class="flagship-title">{p.title}</h3>
            <p class="flagship-desc">{p.description}</p>
            <div class="card-stack">
              {p.stack.map(s => <span class="chip">{s}</span>)}
            </div>
            <div class="card-links">
              {p.links.map(l => (
                <a
                  href={l.href}
                  class={l.label.includes('Case') ? 'btn-link-primary' : 'btn-link-secondary'}
                  target={l.external ? '_blank' : undefined}
                  rel={l.external ? 'noopener noreferrer' : undefined}
                >
                  {l.label}
                </a>
              ))}
            </div>
          </div>
          <div class="flagship-right">
            <div class="outcome-box">
              <span class="outcome-label mono">Outcome</span>
              <span class="outcome-value">{p.outcome}</span>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Themed groups -->
    {(['ai', 'data', 'trustworthy'] as const).map(theme => (
      <div class="theme-group">
        <div class="theme-label reveal">
          <span class="mono" style="font-size: 0.75rem; color: var(--text-lo);">{themeLabels[theme]}</span>
          <hr class="hairline" style="flex: 1;" />
        </div>
        <div class="work-grid">
          {projects.filter(p => p.theme === theme).map((p, i) => (
            <div class="project-card card reveal" style={`--delay: ${i * 80}ms`} id={p.id}>
              <div class="card-preview" data-theme={p.theme} aria-hidden="true"></div>
              <div class="pc-top">
                <h3 class="pc-title">{p.title}</h3>
                <p class="pc-desc">{p.description}</p>
              </div>
              <div class="pc-outcome">
                <span class="mono" style="font-size: 0.7rem; color: var(--signal); text-transform: uppercase; letter-spacing: 0.08em;">Result</span>
                <span style="font-size: 0.82rem; color: var(--text-mid);">{p.outcome}</span>
              </div>
              <div class="card-stack">
                {p.stack.map(s => <span class="chip">{s}</span>)}
              </div>
              <div class="card-links" style="margin-top: auto; padding-top: 16px;">
                {p.links.map(l => (
                  <a
                    href={l.href}
                    class="btn-link-secondary"
                    target={l.external ? '_blank' : undefined}
                    rel={l.external ? 'noopener noreferrer' : undefined}
                  >
                    {l.label}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .work-header {
    margin-bottom: 48px;
  }

  .work-title {
    font-size: var(--step-3);
    margin-top: 12px;
  }

  /* Card hover preview */
  .card-preview {
    position: absolute;
    inset: 0;
    z-index: 0;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 400ms var(--ease-out);
    pointer-events: none;
  }
  .card:hover .card-preview { transform: scaleY(1); }
  .card-preview[data-theme="flagship"] { background: rgba(232, 164, 74, 0.06); }
  .card-preview[data-theme="ai"]        { background: rgba(167, 139, 250, 0.06); }
  .card-preview[data-theme="data"]      { background: rgba(56, 189, 248, 0.06); }
  .card-preview[data-theme="trustworthy"] { background: rgba(251, 113, 133, 0.06); }

  /* Ensure card content sits above preview */
  .flagship-inner { position: relative; z-index: 1; }
  .project-card > *:not(.card-preview) { position: relative; z-index: 1; }

  /* Flagship */
  .flagship-card {
    padding: 40px;
    margin-bottom: 64px;
    position: relative;
    overflow: hidden;
  }

  .flagship-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--signal), transparent);
  }

  .flagship-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .flagship-badge {
    font-size: 0.72rem;
    color: var(--signal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  .flagship-title {
    font-size: var(--step-2);
    margin-bottom: 16px;
  }

  .flagship-desc {
    color: var(--text-mid);
    line-height: 1.7;
    margin-bottom: 24px;
    font-size: 0.95rem;
  }

  .outcome-box {
    background: var(--ink-700);
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .outcome-label {
    font-size: 0.7rem;
    color: var(--signal);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .outcome-value {
    font-size: 0.9rem;
    color: var(--text-hi);
    line-height: 1.5;
  }

  /* Theme groups */
  .theme-group {
    margin-bottom: 64px;
  }

  .theme-label {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .project-card {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    overflow: hidden;
  }

  .pc-top {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pc-title {
    font-size: var(--step-1);
    color: var(--text-hi);
  }

  .pc-desc {
    font-size: 0.85rem;
    color: var(--text-mid);
    line-height: 1.65;
  }

  .pc-outcome {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px;
    background: var(--ink-700);
    border-radius: 2px;
    border-left: 2px solid var(--signal);
  }

  .card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .card-links {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .btn-link-primary {
    padding: 8px 16px;
    background: var(--signal);
    color: var(--signal-ink);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.82rem;
    border-radius: 2px;
    transition: opacity 200ms;
  }

  .btn-link-primary:hover {
    opacity: 0.85;
  }

  .btn-link-secondary {
    padding: 8px 16px;
    background: transparent;
    color: var(--text-mid);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    border: 1px solid var(--line);
    border-radius: 2px;
    transition: color 200ms, border-color 200ms;
  }

  .btn-link-secondary:hover {
    color: var(--text-hi);
    border-color: var(--text-lo);
  }

  @media (max-width: 900px) {
    .flagship-inner {
      grid-template-columns: 1fr;
    }

    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .work-grid {
      grid-template-columns: 1fr;
    }

    .flagship-card {
      padding: 24px;
    }
  }
</style>
