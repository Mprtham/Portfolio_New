---
---
<section class="ct-trigger" aria-hidden="true">
  {Array.from({ length: 50 }).map((_, i) => <div class="ct-box" />)}
</section>

<style>
  .ct-trigger {
    height: 100vh;
    overflow: hidden;
    background-color: var(--ink-900);
  }

  .ct-box {
    height: 1.2vh;
    width: 50vw;
    margin-bottom: -0.2vh;
    background: var(--ink-800);
    border-top: 1px solid var(--line);
    display: block;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initContentTransition() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.ct-trigger').forEach(el => (el as HTMLElement).style.display = 'none');
      return;
    }

    document.querySelectorAll('.ct-trigger').forEach(trigger => {
      gsap
        .timeline({
          scrollTrigger: {
            trigger,
            scrub: 0.5,
            pin: true,
            start: 'top top',
            end: '+=100%',
          },
        })
        .to('.ct-box', {
          force3D: true,
          duration: 1,
          xPercent: 100,
          ease: 'power1.inOut',
          stagger: { amount: 1 },
        })
        .to('.ct-box', { ease: 'power1.out', duration: 1, rotation: '45deg' }, 0)
        .to('.ct-box', { ease: 'power1.in', duration: 1, rotation: '0deg' }, 1);
    });
  }

  initContentTransition();
  document.addEventListener('astro:page-load', initContentTransition);
</script>
