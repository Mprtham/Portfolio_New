---
import SkillsFilter from './react/SkillsFilter';

const stack = ['Power BI', 'BigQuery', 'dbt', 'PostgreSQL', 'GA4', 'Python', 'LangGraph', 'FastAPI', 'Docker', 'scikit-learn', 'SHAP', 'Plotly', 'Tableau', 'Airflow', 'Qdrant', 'ChromaDB', 'Groq', 'Azure OpenAI', 'Langfuse', 'RAGAS', 'Polars', 'Streamlit', 'React', 'GitHub Actions', 'Kafka', 'DuckDB'];
---

<section id="skills">
  <div class="container">
    <div class="skills-header reveal">
      <span class="section-label">05 Skills as Systems</span>
      <div class="skills-title-row">
        <h2 class="skills-title">What I reach for<br />and how deep I go.</h2>
        <p class="skills-hint mono">Filter by project →</p>
      </div>
    </div>

    <div class="reveal" style="--delay: 100ms;">
      <SkillsFilter client:visible />
    </div>

    <!-- Stack marquee -->
    <div class="stack-marquee reveal" style="--delay: 200ms;" aria-label="Full technology stack">
      <div class="marquee-track">
        {[...stack, ...stack].map(t => (
          <span class="marquee-item mono">{t}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .skills-header {
    margin-bottom: 32px;
  }

  .skills-title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .skills-title {
    font-size: var(--step-3);
  }

  .skills-hint {
    font-size: var(--step--1);
    color: var(--text-lo);
  }

  .stack-marquee {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 12px 0;
    background: var(--ink-800);
    margin-top: 32px;
  }

  .marquee-track {
    display: flex;
    animation: marquee 28s linear infinite;
    width: max-content;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .marquee-item {
    font-size: 0.75rem;
    color: var(--text-lo);
    padding: 0 20px;
    border-right: 1px solid var(--line);
    white-space: nowrap;
    transition: color 200ms;
  }

  .marquee-item:hover {
    color: var(--text-hi);
  }
</style>
