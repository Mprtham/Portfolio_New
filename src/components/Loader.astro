---
---
<div id="loader-wrapper" style="display:none">
  <div class="loader-body">
    <div class="loader-name mono">PM</div>
    <p class="counter" id="loader-count">0<span class="counter-unit">%</span></p>
  </div>
  <div class="progress-bar" id="loader-progress"></div>
</div>

<style>
  #loader-wrapper {
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: var(--ink-900);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    will-change: transform;
    transition: transform 700ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  #loader-wrapper.loader--exit {
    transform: translateY(-100%);
  }

  .loader-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .loader-name {
    font-size: 0.78rem;
    letter-spacing: 0.25em;
    color: var(--text-lo);
    text-transform: uppercase;
  }

  .counter {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: clamp(64px, 12vw, 120px);
    font-weight: 700;
    color: var(--signal);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .counter-unit {
    font-size: 0.4em;
    letter-spacing: 0;
    opacity: 0.6;
    vertical-align: super;
    margin-left: 2px;
  }

  .progress-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    height: 2px;
    background: var(--signal);
    width: 0%;
    will-change: width;
    transition: width 50ms linear;
    box-shadow: 0 0 8px rgba(232, 164, 74, 0.5);
  }
</style>

<script>
  (function () {
    const wrapper = document.getElementById('loader-wrapper') as HTMLElement | null;
    if (!wrapper) return;

    if (sessionStorage.getItem('loaderDone')) {
      wrapper.remove();
      document.body.classList.add('loader-done');
      return;
    }

    const countEl = document.getElementById('loader-count');
    const progressEl = document.getElementById('loader-progress') as HTMLElement;
    if (!countEl || !progressEl) return;

    wrapper.style.display = '';

    const DURATION = 800;
    const start = performance.now();

    function frame(now: number) {
      const elapsed = now - start;
      const pct = Math.min(elapsed / DURATION, 1);
      const count = Math.floor(pct * 100);

      countEl!.childNodes[0].textContent = String(count);
      progressEl.style.width = `${pct * 100}%`;

      if (pct < 1) {
        requestAnimationFrame(frame);
      } else {
        countEl!.childNodes[0].textContent = '100';
        progressEl.style.width = '100%';
        wrapper!.classList.add('loader--exit');
        wrapper!.addEventListener('transitionend', () => {
          wrapper!.remove();
          document.body.classList.add('loader-done');
          sessionStorage.setItem('loaderDone', '1');
        }, { once: true });
      }
    }

    requestAnimationFrame(frame);
  })();
</script>
