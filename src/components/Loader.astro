---
---
<div id="loader-wrapper">
  <div class="counter-container">
    <p class="counter" id="loader-count">0</p>
    <div class="progress-bar" id="loader-progress"></div>
  </div>
</div>

<style>
  #loader-wrapper {
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: var(--ink-900);
    will-change: transform;
    transition: transform 800ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  #loader-wrapper.loader--exit {
    transform: translateY(-100%);
  }

  .counter-container {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 3rem 4rem;
    height: 100vh;
    width: 100vw;
  }

  .counter {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: clamp(80px, 15vw, 160px);
    font-weight: 700;
    color: var(--signal);
    line-height: 1;
    letter-spacing: -0.04em;
    will-change: contents;
    margin: 0;
  }

  .progress-bar {
    height: 2px;
    background: var(--signal);
    width: 0%;
    margin-top: 1.25rem;
    max-width: 100%;
    will-change: width;
    transition: width 50ms linear;
  }
</style>

<script>
  const DURATION = 1600;

  function runLoader() {
    if (sessionStorage.getItem('loaderDone')) return;

    const wrapper = document.getElementById('loader-wrapper');
    const countEl = document.getElementById('loader-count');
    const progressEl = document.getElementById('loader-progress') as HTMLElement;
    if (!wrapper || !countEl || !progressEl) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      countEl.textContent = '100';
      progressEl.style.width = '100%';
      wrapper.classList.add('loader--exit');
      wrapper.addEventListener('transitionend', () => {
        wrapper.remove();
        sessionStorage.setItem('loaderDone', '1');
        document.dispatchEvent(new CustomEvent('intro:complete'));
      }, { once: true });
      return;
    }

    const startTime = performance.now();

    function tick(now: number) {
      const progress = Math.min((now - startTime) / DURATION, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const value = Math.floor(eased * 100);

      countEl!.textContent = String(value);
      progressEl.style.width = `${value}%`;

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        countEl!.textContent = '100';
        progressEl.style.width = '100%';

        setTimeout(() => {
          wrapper!.classList.add('loader--exit');
          wrapper!.addEventListener('transitionend', () => {
            wrapper!.remove();
            sessionStorage.setItem('loaderDone', '1');
            document.dispatchEvent(new CustomEvent('intro:complete'));
          }, { once: true });
        }, 180);
      }
    }

    requestAnimationFrame(tick);
  }

  runLoader();
</script>
