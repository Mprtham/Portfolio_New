---
---
<div id="cursor" aria-hidden="true">
  <div class="cursor-dot"></div>
  <div class="cursor-ring"></div>
</div>

<style>
  #cursor {
    pointer-events: none;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9999;
  }

  .cursor-dot {
    width: 8px;
    height: 8px;
    background: var(--signal);
    border-radius: 50%;
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    will-change: transform;
    box-shadow: 0 0 8px var(--signal), 0 0 18px rgba(232,164,74,0.5);
  }

  .cursor-ring {
    width: 30px;
    height: 30px;
    border: 1.5px solid rgba(232,164,74,0.8);
    border-radius: 50%;
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    will-change: transform;
    opacity: 0.85;
  }

  .cursor-ring.hovering {
    opacity: 1;
    border-color: var(--signal);
    box-shadow: 0 0 12px rgba(232,164,74,0.4);
  }

  @media (hover: none), (max-width: 1024px) {
    #cursor { display: none !important; }
  }
</style>

<script>
  let cursorRaf: number | null = null;
  let cursorMouseHandler: ((e: MouseEvent) => void) | null = null;
  let cursorOverHandler: ((e: MouseEvent) => void) | null = null;
  let cursorOutHandler: ((e: MouseEvent) => void) | null = null;

  function initCursor() {
    if (cursorRaf) cancelAnimationFrame(cursorRaf);
    if (cursorMouseHandler) window.removeEventListener('mousemove', cursorMouseHandler);
    if (cursorOverHandler) document.removeEventListener('mouseover', cursorOverHandler);
    if (cursorOutHandler) document.removeEventListener('mouseout', cursorOutHandler);

    const hasHover = window.matchMedia('(hover: hover)').matches;
    const isWide = window.innerWidth > 1024;
    if (!hasHover || !isWide) return;

    const dot = document.querySelector('.cursor-dot') as HTMLElement;
    const ring = document.querySelector('.cursor-ring') as HTMLElement;
    if (!dot || !ring) return;

    let mouseX = -100, mouseY = -100;
    let ringX = -100, ringY = -100;
    let isHovering = false;
    let ringScale = 1;
    let targetScale = 1;

    cursorMouseHandler = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      dot.style.transform = `translate(${mouseX - 3}px, ${mouseY - 3}px)`;
    };

    const hoverTargets = 'a, button, [data-hover], .card, .chip, .hl-chip';

    cursorOverHandler = (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(hoverTargets)) {
        isHovering = true;
        targetScale = 2.2;
        ring.classList.add('hovering');
      }
    };

    cursorOutHandler = (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest(hoverTargets)) {
        isHovering = false;
        targetScale = 1;
        ring.classList.remove('hovering');
      }
    };

    window.addEventListener('mousemove', cursorMouseHandler);
    document.addEventListener('mouseover', cursorOverHandler);
    document.addEventListener('mouseout', cursorOutHandler);

    function loop() {
      ringX += (mouseX - ringX) * 0.12;
      ringY += (mouseY - ringY) * 0.12;
      ringScale += (targetScale - ringScale) * 0.15;

      ring.style.transform = `translate(${ringX - 14}px, ${ringY - 14}px) scale(${ringScale.toFixed(3)})`;

      cursorRaf = requestAnimationFrame(loop);
    }

    loop();
  }

  initCursor();
  document.addEventListener('astro:page-load', initCursor);
  document.addEventListener('astro:before-swap', () => {
    if (cursorRaf) cancelAnimationFrame(cursorRaf);
    if (cursorMouseHandler) window.removeEventListener('mousemove', cursorMouseHandler);
    if (cursorOverHandler) document.removeEventListener('mouseover', cursorOverHandler);
    if (cursorOutHandler) document.removeEventListener('mouseout', cursorOutHandler);
  });
</script>
