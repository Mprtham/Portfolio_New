---
const socials = [
  { label: 'LinkedIn', href: 'https://linkedin.com/in/prathameshmishra07', icon: 'LI' },
  { label: 'GitHub', href: 'https://github.com/Mprtham', icon: 'GH' },
  { label: 'Medium', href: 'https://medium.com/@mishraprathamesh2303', icon: 'M·' },
];
---

<section id="contact">
  <div class="container">
    <div class="contact-inner">
      <div class="contact-left reveal">
        <span class="section-label">07 Contact</span>
        <h2 class="contact-heading">Have a question<br />hiding in your data?<br /><span class="signal-text">Let's find it.</span></h2>

        <div class="contact-links">
          <a href="mailto:mprathamesh2023@gmail.com" class="contact-link">
            <span class="contact-link-label mono">Email</span>
            <span class="contact-link-value">mprathamesh2023@gmail.com</span>
          </a>
          <a href="tel:+447748999614" class="contact-link">
            <span class="contact-link-label mono">Phone</span>
            <span class="contact-link-value">+44 7748 999614</span>
          </a>
        </div>

        <div class="socials">
          {socials.map(s => (
            <a href={s.href} class="social-btn" target="_blank" rel="noopener noreferrer" aria-label={s.label}>
              <span class="mono">{s.icon}</span>
              <span>{s.label}</span>
            </a>
          ))}
          <a href="/cv.pdf" class="social-btn cta" target="_blank" rel="noopener">
            <span class="mono">↓</span>
            <span>Download CV</span>
          </a>
        </div>
      </div>

      <div class="contact-right reveal" style="animation-delay: 120ms;">
        <form class="contact-form" name="contact" action="https://formspree.io/f/placeholder" method="POST" novalidate>
          <div class="form-field">
            <label for="name" class="form-label mono">Name</label>
            <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required />
          </div>
          <div class="form-field">
            <label for="email" class="form-label mono">Email</label>
            <input type="email" id="email" name="email" class="form-input" placeholder="you@company.com" required />
          </div>
          <div class="form-field">
            <label for="message" class="form-label mono">Message</label>
            <textarea id="message" name="message" class="form-input form-textarea" placeholder="What are you working on?" rows="5" required></textarea>
          </div>
          <button type="submit" class="form-submit">Send message →</button>
        </form>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container footer-inner">
    <span class="mono footer-copy" style="font-size: 0.72rem; color: var(--text-lo);">
      © 2025 Prathamesh Mishra · London, UK
    </span>
    <span class="footer-note mono" style="font-size: 0.72rem; color: var(--text-lo);">
      Built with Astro · Cookieless analytics · GDPR-clean
    </span>
  </div>
</footer>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .contact-heading {
    font-size: var(--step-3);
    margin-top: 12px;
    margin-bottom: 40px;
    line-height: 1.05;
  }

  .signal-text {
    color: var(--signal);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .contact-link {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 14px 16px;
    background: var(--ink-800);
    border: 1px solid var(--line);
    border-radius: 2px;
    transition: border-color 200ms;
  }

  .contact-link:hover {
    border-color: rgba(92, 242, 192, 0.3);
  }

  .contact-link-label {
    font-size: 0.7rem;
    color: var(--text-lo);
    width: 48px;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .contact-link-value {
    font-size: 0.88rem;
    color: var(--text-hi);
  }

  .socials {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .social-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: var(--ink-700);
    border: 1px solid var(--line);
    border-radius: 2px;
    font-size: 0.8rem;
    color: var(--text-mid);
    transition: color 200ms, border-color 200ms;
  }

  .social-btn:hover {
    color: var(--text-hi);
    border-color: var(--text-lo);
  }

  .social-btn.cta {
    border-color: var(--signal);
    color: var(--signal);
  }

  .social-btn.cta:hover {
    background: var(--signal);
    color: var(--signal-ink);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 0.72rem;
    color: var(--text-lo);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .form-input {
    background: var(--ink-800);
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 12px 14px;
    color: var(--text-hi);
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    transition: border-color 200ms;
    outline: none;
    resize: none;
  }

  .form-input::placeholder {
    color: var(--text-lo);
  }

  .form-input:focus {
    border-color: var(--signal);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    padding: 12px 24px;
    background: var(--signal);
    color: var(--signal-ink);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: opacity 200ms;
    align-self: flex-start;
  }

  .form-submit:hover {
    opacity: 0.88;
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--line);
    padding: 24px 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media (max-width: 768px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
