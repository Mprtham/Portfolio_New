---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="CV — Prathamesh Mishra | Data & Product Analyst"
  description="CV of Prathamesh Mishra — Data & Product Analyst, Power BI, SQL, GA4 and production AI systems. Based in London."
>
  <main style="padding-top: 80px;">
    <div class="container cv-page">

      <div class="cv-header reveal">
        <div>
          <h1 class="cv-name">Prathamesh Mishra</h1>
          <p class="cv-role">Data & Product Analyst · AI Systems Builder</p>
          <p class="cv-location mono">London, UK</p>
        </div>
        <div class="cv-actions">
          <button onclick="window.print()" class="btn-dl">↓ Save as PDF</button>
          <a href="/#contact" class="btn-contact">Get in touch</a>
        </div>
      </div>

      <hr class="hairline" style="margin: 32px 0;" />

      <!-- Contact strip -->
      <div class="cv-contacts reveal">
        <a href="mailto:mprathamesh2023@gmail.com" class="cv-contact-item">
          <span class="mono cv-contact-label">Email</span>
          <span>mprathamesh2023@gmail.com</span>
        </a>
        <a href="tel:+447748999614" class="cv-contact-item">
          <span class="mono cv-contact-label">Phone</span>
          <span>+44 7748 999614</span>
        </a>
        <a href="https://linkedin.com/in/prathameshmishra07" target="_blank" rel="noopener" class="cv-contact-item">
          <span class="mono cv-contact-label">LinkedIn</span>
          <span>prathameshmishra07</span>
        </a>
        <a href="https://github.com/Mprtham" target="_blank" rel="noopener" class="cv-contact-item">
          <span class="mono cv-contact-label">GitHub</span>
          <span>Mprtham</span>
        </a>
      </div>

      <div class="cv-body">

        <!-- Summary -->
        <section class="cv-section reveal">
          <h2 class="cv-section-title">Profile</h2>
          <p class="cv-para">
            Data and product analyst with 4+ years across pharma, fintech, and hospitality. I build the full analytics loop — from SQL and Python pipelines, through Power BI executive dashboards, to the recommendation that changes the decision. Alongside BI, I ship production AI systems: multi-agent pipelines, autonomous analyst agents, RAG platforms, and real-time anomaly detection.
          </p>
        </section>

        <!-- Experience -->
        <section class="cv-section reveal">
          <h2 class="cv-section-title">Experience</h2>

          <div class="cv-role-block">
            <div class="cv-role-header">
              <div>
                <h3 class="cv-role-title">Data Analyst</h3>
                <span class="cv-company">Pharmaceutical UK Ltd</span>
              </div>
              <span class="mono cv-period">Jan 2025 – Present</span>
            </div>
            <ul class="cv-bullets">
              <li>Drove +30% organic acquisition (12k → 15.6k monthly sign-ups) and −22% CAC via SQL segmentation and A/B testing across 20+ experiments.</li>
              <li>Built ±8% accuracy demand-forecast models in SQL/Python informing ~£200K revenue targeting.</li>
              <li>Delivered Power BI executive dashboards with DAX and Power Query, cutting reporting cycle from 2 weeks to 2 days.</li>
              <li>Reduced manual reporting effort by 50% through automated Python/SQL pipelines.</li>
              <li>Managed GDPR-compliant data flows; implemented GA4 event taxonomy and connected to Power BI via BigQuery export.</li>
              <li>Achieved +12% retention improvement through cohort and RFM segmentation on 50k+ MAU.</li>
            </ul>
          </div>

          <div class="cv-role-block">
            <div class="cv-role-header">
              <div>
                <h3 class="cv-role-title">Analytics Consultant</h3>
                <span class="cv-company">Charac (NHS-Integrated Pharmacy Platform)</span>
              </div>
              <span class="mono cv-period">2024 – Present</span>
            </div>
            <ul class="cv-bullets">
              <li>Built Power BI + GA4 analytics layer for prescription, delivery, and consultation KPIs across pharmacy owner and patient-facing portals.</li>
              <li>Designed DirectQuery Power BI dashboards with DAX measures for NHS-calendar-aware SLA tracking.</li>
              <li>Implemented GA4 event taxonomy and BigQuery export pipeline; connected acquisition attribution to Power BI.</li>
              <li>All work scoped within GDPR and NHS Information Governance requirements.</li>
            </ul>
          </div>

          <div class="cv-role-block">
            <div class="cv-role-header">
              <div>
                <h3 class="cv-role-title">Data Scientist</h3>
                <span class="cv-company">Smallcap Networks</span>
              </div>
              <span class="mono cv-period">Aug 2024 – Apr 2025</span>
            </div>
            <ul class="cv-bullets">
              <li>Designed and executed 20+ end-to-end A/B experiments — hypothesis, instrumentation, analysis, and roadmap recommendation.</li>
              <li>Modelled 1M+ user behavioural records for churn reduction; delivered insights within 2-day SLAs.</li>
              <li>Built Python/SQL pipelines transforming raw event data into stakeholder-ready dashboards.</li>
            </ul>
          </div>

          <div class="cv-role-block">
            <div class="cv-role-header">
              <div>
                <h3 class="cv-role-title">Operations Analyst (Contract)</h3>
                <span class="cv-company">Hampton by Hilton</span>
              </div>
              <span class="mono cv-period">Sep 2024 – Mar 2025</span>
            </div>
            <ul class="cv-bullets">
              <li>Cohort analysis on 12 months of booking data identified retention levers, driving +9% repeat bookings.</li>
              <li>Automated reporting pipelines reducing weekly manual effort by 50%.</li>
            </ul>
          </div>

          <div class="cv-role-block">
            <div class="cv-role-header">
              <div>
                <h3 class="cv-role-title">Python Developer</h3>
                <span class="cv-company">Sahu Technologies</span>
              </div>
              <span class="mono cv-period">2022 – 2023</span>
            </div>
            <ul class="cv-bullets">
              <li>Developed Python automation scripts and ETL data processing pipelines for internal tooling.</li>
            </ul>
          </div>
        </section>

        <!-- Projects -->
        <section class="cv-section reveal">
          <h2 class="cv-section-title">Selected Projects</h2>

          <div class="cv-project-grid">
            {[
              { name: 'PeopleOps Analytics', desc: 'BigQuery + dbt + Power BI HR attrition platform. ROC-AUC 0.665, 3× PR-AUC over baseline, 75/75 dbt tests, PBIP in Git with BPA CI gate.', link: 'github.com/Mprtham/peopleops-risk-intelligence' },
              { name: 'Sentinel', desc: 'LangGraph agent: 100+ events/sec Kafka ingestion, DuckDB anomaly detection, AI root-cause report in <90s. <10% false-positive rate.', link: 'github.com/Mprtham/Real-Time-Anomaly-Detection-Agent' },
              { name: 'Agentic Data Analyst', desc: 'ReAct agent over a statistical tool registry. Sandboxed Docker execution, ChromaDB session memory, auto-generated reports.', link: 'github.com/Mprtham/Agentic-Data-Analyst' },
              { name: 'SQL Forge', desc: 'Fine-tuned Phi-3-mini for BigQuery + dbt SQL. 15% → 55% exact-match, 60% → 90% parse accuracy.', link: 'github.com/Mprtham/BigQuery-dbt-Text-to-SQL-Fine-Tuner' },
              { name: 'RAG Observatory', desc: 'Production RAG with cross-encoder reranking, Langfuse tracing, RAGAS CI quality gates.', link: 'github.com/Mprtham/rag-observatory' },
              { name: 'SecureQuery AI', desc: 'Defence-in-depth RBAC RAG: Qdrant payload filters, JWT, Presidio PII masking, 185 tests in ~2s.', link: 'github.com/Mprtham/securequery-ai' },
            ].map(p => (
              <div class="cv-project">
                <div class="cv-project-name">{p.name}</div>
                <p class="cv-project-desc">{p.desc}</p>
                <span class="mono" style="font-size: 0.7rem; color: var(--text-lo);">{p.link}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Skills -->
        <section class="cv-section reveal">
          <h2 class="cv-section-title">Skills</h2>
          <div class="cv-skills-grid">
            {[
              { cat: 'BI & Visualisation', items: 'Power BI (DAX, Copilot, PBIP), Tableau, Looker Studio, Plotly, Excel (Power Query)' },
              { cat: 'Data & SQL', items: 'BigQuery, PostgreSQL, dbt, Airflow, ETL/ELT, data modelling' },
              { cat: 'Analytics', items: 'GA4, A/B testing, cohort analysis, RFM segmentation, forecasting, statistical testing (t-test, ANOVA, chi-square)' },
              { cat: 'Python & ML', items: 'pandas, NumPy, scikit-learn, Polars, LSTM, Prophet, SHAP' },
              { cat: 'AI Systems', items: 'LangGraph, RAG, Qdrant, ChromaDB, fine-tuning (LoRA/DPO), FastAPI, Docker' },
              { cat: 'Other', items: 'GDPR, NHS IG, GitHub Actions, Langfuse, RAGAS, Streamlit' },
            ].map(s => (
              <div class="cv-skill-row">
                <span class="cv-skill-cat mono">{s.cat}</span>
                <span class="cv-skill-items">{s.items}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Education -->
        <section class="cv-section reveal">
          <h2 class="cv-section-title">Education</h2>
          <div class="cv-role-block">
            <div class="cv-role-header">
              <div>
                <h3 class="cv-role-title">MSc Data Science & Artificial Intelligence</h3>
                <span class="cv-company">University — UK</span>
              </div>
              <span class="mono cv-period">2023 – 2024</span>
            </div>
            <p style="font-size: 0.85rem; color: var(--text-mid); margin-top: 8px;">Dissertation: Hybrid LSTM + Prophet stock price prediction with NLP sentiment analysis — 80k+ tweets, 25 companies, Sharpe ratio 0.719.</p>
          </div>
        </section>

      </div>
    </div>
  </main>
</Layout>

<style>
  .cv-page {
    padding-top: 48px;
    padding-bottom: 96px;
    max-width: 860px;
  }

  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    flex-wrap: wrap;
  }

  .cv-name {
    font-size: var(--step-3);
    margin-bottom: 6px;
  }

  .cv-role {
    font-size: var(--step-1);
    color: var(--text-mid);
    margin-bottom: 4px;
  }

  .cv-location {
    font-size: var(--step--1);
    color: var(--text-lo);
  }

  .cv-actions {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-dl {
    padding: 10px 20px;
    background: var(--signal);
    color: var(--signal-ink);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    border-radius: 2px;
    transition: opacity 200ms;
  }
  .btn-dl:hover { opacity: 0.85; }

  .btn-contact {
    padding: 10px 20px;
    border: 1px solid var(--line);
    color: var(--text-mid);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.88rem;
    border-radius: 2px;
    transition: border-color 200ms, color 200ms;
  }
  .btn-contact:hover { border-color: var(--text-lo); color: var(--text-hi); }

  .cv-contacts {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .cv-contact-item {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 12px 20px 12px 0;
    margin-right: 20px;
    font-size: 0.82rem;
    color: var(--text-mid);
    transition: color 200ms;
    border-right: 1px solid var(--line);
    padding-right: 20px;
  }
  .cv-contact-item:last-child { border-right: none; }
  .cv-contact-item:hover { color: var(--text-hi); }

  .cv-contact-label {
    font-size: 0.68rem;
    color: var(--text-lo);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .cv-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cv-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--line);
  }
  .cv-section:last-child { border-bottom: none; }

  .cv-section-title {
    font-size: var(--step-0);
    color: var(--signal);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
  }

  .cv-para {
    color: var(--text-mid);
    line-height: 1.75;
    font-size: 0.92rem;
  }

  .cv-role-block {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line);
  }
  .cv-role-block:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .cv-role-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .cv-role-title {
    font-size: var(--step-0);
    color: var(--text-hi);
    margin-bottom: 3px;
  }

  .cv-company {
    font-size: 0.85rem;
    color: var(--text-mid);
  }

  .cv-period {
    font-size: 0.75rem;
    color: var(--text-lo);
    white-space: nowrap;
  }

  .cv-bullets {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .cv-bullets li {
    font-size: 0.87rem;
    color: var(--text-mid);
    line-height: 1.65;
    padding-left: 14px;
    position: relative;
  }

  .cv-bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--signal);
    font-size: 0.75rem;
  }

  .cv-project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .cv-project {
    padding: 16px;
    background: var(--ink-800);
    border: 1px solid var(--line);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cv-project-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--text-hi);
  }

  .cv-project-desc {
    font-size: 0.8rem;
    color: var(--text-mid);
    line-height: 1.6;
  }

  .cv-skills-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 2px;
    overflow: hidden;
  }

  .cv-skill-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 16px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }
  .cv-skill-row:last-child { border-bottom: none; }
  .cv-skill-row:nth-child(odd) { background: var(--ink-800); }
  .cv-skill-row:nth-child(even) { background: var(--ink-700); }

  .cv-skill-cat {
    font-size: 0.72rem;
    color: var(--signal);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .cv-skill-items {
    font-size: 0.83rem;
    color: var(--text-mid);
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .cv-project-grid { grid-template-columns: 1fr; }
    .cv-skill-row { grid-template-columns: 1fr; gap: 4px; }
    .cv-contacts { flex-direction: column; }
    .cv-contact-item { border-right: none; border-bottom: 1px solid var(--line); margin-right: 0; padding-right: 0; }
  }
</style>
